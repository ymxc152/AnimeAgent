# LLM 配置
LLM_PROVIDER=openai          # openai / ollama
OPENAI_API_KEY=sk-xxx
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen2.5:7b

# qBittorrent
QB_HOST=http://localhost:8080
QB_USERNAME=admin
QB_PASSWORD=adminadmin
QB_SAVE_PATH=C:\Downloads\Anime

# Emby
EMBY_HOST=http://localhost:8096
EMBY_API_KEY=xxx
EMBY_LIBRARY_NAME=Anime

# TMDB
TMDB_API_KEY=xxx
TMDB_READ_ACCESS_TOKEN=xxx

# RSS
RSS_DEFAULT_URL=

# 媒体库
MEDIA_LIBRARY_PATH=C:\Media\Anime
ORGANIZE_TEMPLATE="{series_title}\Season{season:02d}\S{season:02d}E{episode:02d}.{series_title}.{ext}"

# 系统
CHECK_INTERVAL_SECONDS=60
RSS_WAIT_INTERVAL_SECONDS=21600
DISCOVERY_CRON="0 0 * * 1"
LOG_LEVEL=INFO
DATABASE_URL=sqlite+aiosqlite:///anime_agent.db

# 系统检测（首次启动自动写入）
OS_TYPE=auto

# Agent 过滤规则
FILTER_EXCLUDE_OVA=true
FILTER_EXCLUDE_MOVIES=false
FILTER_MIN_DURATION_MINUTES=5
FILTER_EXCLUDE_GENRES=Hentai
FILTER_EXCLUDE_FORMATS=OVA,ONA
FILTER_REQUIRE_ANIME_TYPE=true
FILTER_AUTO_SUBSCRIBE_NEW_SEASON=true

# AnimeGarden / 资源回退
ANIME_GARDEN_BASE_URL=https://api.animes.garden
ANIME_GARDEN_TIMEOUT_SECONDS=30
ANIME_GARDEN_CACHE_TTL_SECONDS=3600
RESOURCE_FALLBACK_ENABLED=true
RESOURCE_FALLBACK_OLD_ANIME_DAYS=90
RESOURCE_SEARCH_MAX_PAGES=1

# 通知（可选）
APPRISE_URLS=
